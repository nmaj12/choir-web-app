@model choir_app.Models.Events

@{
    ViewData["Title"] = "Szczegóły wydarzenia";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-hero-mini">
    <div class="container">
        <h1 class="anim-fade-up">Szczegóły wydarzenia</h1>
    </div>
</div>

<section class="events-page">
    <div class="container">
        <div class="dash-card" style="max-width: 600px; margin: 0 auto;">
            <h2 style="font-family: var(--font-display); margin-bottom: 1.5rem;">@Model.Name</h2>

            <div style="margin-bottom: 2rem;">
                <p style="margin-bottom: 0.5rem;"><strong>Data:</strong> @Model.Date.ToString("dd MMMM yyyy, HH:mm")</p>
                <p><strong>Lokalizacja:</strong> @Model.Location</p>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn-outline-choir">Powrót do listy</a>

                @if (User.IsInRole("Admin") || User.IsInRole("Dyrygent"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-choir">Edytuj wydarzenie</a>
                }

                @if (User.Identity.IsAuthenticated)
                {
                    <form asp-action="Subscribe" asp-controller="Events" method="post">
                        <input type="hidden" name="eventId" value="@Model.Id" />
                        <button type="submit" class="btn-primary-choir" style="background-color: var(--clr-gold);">
                            <i class="bi bi-bell"></i> Obserwuj
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</section>