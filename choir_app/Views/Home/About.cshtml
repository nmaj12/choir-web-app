@{
    ViewData["Title"] = "O nas";
    ViewData["ActivePage"] = "About";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-hero-mini">
    <div class="container">
        <h1 class="anim-fade-up">O nas</h1>
        <p class="anim-fade-up anim-delay-1">Poznaj historię i misję Chóru Akademickiego</p>
    </div>
</div>

<section style="padding:4rem 0;">
    <div class="container">
        <div class="intro-grid">
            <div class="reveal">
                <div class="section-heading">
                    <span class="overline">Nasza historia</span>
                    <h2>Ponad 30 lat muzycznej pasji</h2>
                    <p>
                        Chór Akademicki został założony w 1993 roku z inicjatywy grupy studentów
                        zafascynowanych muzyką chóralną. Od tamtej pory wyrósł na jeden z najbardziej
                        rozpoznawalnych zespołów wokalnych w regionie.
                    </p>
                </div>
                <div class="intro-features">
                    <div class="intro-feature">
                        <div class="feat-icon"><i class="bi bi-trophy"></i></div>
                        <h5>Nagrody</h5>
                        <p>Wielokrotni laureaci ogólnopolskich i międzynarodowych konkursów chóralnych.</p>
                    </div>
                    <div class="intro-feature">
                        <div class="feat-icon"><i class="bi bi-globe2"></i></div>
                        <h5>Tournée</h5>
                        <p>Wystąpiliśmy w 15 krajach Europy, Azji i Ameryki Północnej.</p>
                    </div>
                    <div class="intro-feature">
                        <div class="feat-icon"><i class="bi bi-music-note-list"></i></div>
                        <h5>Repertuar</h5>
                        <p>Od renesansu po muzykę współczesną — ponad 200 utworów w repertuarze.</p>
                    </div>
                    <div class="intro-feature">
                        <div class="feat-icon"><i class="bi bi-people"></i></div>
                        <h5>Wspólnota</h5>
                        <p>60 chórzystów tworzących wyjątkową rodzinę muzyczną.</p>
                    </div>
                </div>
            </div>
            <div class="reveal" style="display:flex;align-items:center;justify-content:center;">
                <div style="width:100%; aspect-ratio:4/5; border-radius:12px; overflow:hidden; box-shadow: 0 15px 30px rgba(0,0,0,0.15);">
                    <img src="https://images.unsplash.com/photo-1552422535-c45813c61732?q=80&w=800" alt="Fortepian" style="width:100%; height:100%; object-fit:cover;" />
                </div>
            </div>
        </div>
    </div>
</section>
