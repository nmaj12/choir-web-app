@model choir_app.Models.ChoirMember

@{
    ViewData["Title"] = "Edit Choir Member";
}

<h2>Edit Choir Member</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div>
        <label>User</label>
        <input value="@Model.User?.UserName" disabled />
    </div>

    <div>
        <label>Voice</label>
        <select asp-for="Voice" asp-items="Html.GetEnumSelectList<choir_app.Models.Enums.VoiceType>()">
        </select>
    </div>

    <div>
        <label>Is Active</label>
        <input asp-for="IsActive" type="checkbox" />
    </div>

    <div>
        <label>Notes</label>
        <textarea asp-for="Notes"></textarea>
    </div>

    <button type="submit">Save</button>
</form>