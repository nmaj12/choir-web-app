<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Chór Akademicki</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <nav class="choir-nav" id="mainNav">
        <div class="container">
            <div class="nav-inner">

                <a class="nav-brand" href="/">
                    <span class="brand-icon"><i class="bi bi-music-note-beamed"></i></span>
                    <span class="brand-text">
                        <span class="brand-name">Chór Akademicki</span>
                        <span class="brand-sub">Universitas Musicae</span>
                    </span>
                </a>

                <ul class="nav-links" id="navLinks">
                    <li><a href="/" class="nav-link @(ViewData["ActivePage"] as string == "Home"    ? "active" : "")">Strona główna</a></li>
                    <li><a href="/Gallery" class="nav-link @(ViewData["ActivePage"] as string == "Gallery" ? "active" : "")">Galeria</a></li>
                    <li><a href="/Events" class="nav-link @(ViewData["ActivePage"] as string == "Events"  ? "active" : "")">Wydarzenia</a></li>
                    <li><a href="/Home/About" class="nav-link @(ViewData["ActivePage"] as string == "About"   ? "active" : "")">O nas</a></li>
                    <li><a href="/Home/Contact" class="nav-link @(ViewData["ActivePage"] as string == "Contact" ? "active" : "")">Kontakt</a></li>
                    <li><a href="/FaqEntries" class="nav-link @(ViewData["ActivePage"] as string == "FaqEntries" ? "active" : "")">FAQ</a></li>

                </ul>

                <div class="nav-auth">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="dropdown">
                            <button class="btn-member dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i>
                                <span>@User.Identity.Name</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-controller="ChoirDashboard" asp-action="Index">
                                        <i class="bi bi-speedometer2 me-2"></i>Panel chórzysty
                                    </a>
                                </li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li>
                                        <a class="dropdown-item" href="/Admin/Dashboard">
                                            <i class="bi bi-gear me-2"></i>Panel admina
                                        </a>
                                    </li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-action="Logout" asp-controller="Account" method="post">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Wyloguj
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn-login">Zaloguj się</a>
                    }
                </div>

                <button class="nav-hamburger" id="hamburgerBtn" aria-label="Otwórz menu" aria-expanded="false">
                    <span></span><span></span><span></span>
                </button>
            </div>
        </div>

        <div class="mobile-menu" id="mobileMenu">
            <ul>
                <li><a href="/">Strona główna</a></li>
                <li><a href="/Gallery">Galeria</a></li>
                <li><a href="/Events">Wydarzenia</a></li>
                <li><a href="/Home/About">O nas</a></li>
                <li><a href="/Home/Contact">Kontakt</a></li>
                <li><a href="/FaqEntries">FAQ</a></li>


                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <li class="mobile-divider"></li>
                    <li><a asp-controller="ChoirDashboard" asp-action="Index">Panel chórzysty</a></li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li><a href="/Admin/Dashboard">Panel admina</a></li>
                    }
                }
                else
                {
                    <li class="mobile-divider"></li>
                    <li><a href="/Account/Login" class="mobile-login">Zaloguj się</a></li>
                }
            </ul>
        </div>
    </nav>

    <main id="pageContent">
        @RenderBody()
    </main>

    <footer class="choir-footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <a href="/" class="footer-logo">
                        <i class="bi bi-music-note-beamed"></i> Chór Akademicki
                    </a>
                    <p>Łączymy głosy, serca i pasję od ponad 30 lat.</p>
                    <div class="footer-socials">
                        <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                        <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                    </div>
                </div>
                <div class="footer-links">
                    <h4>Nawigacja</h4>
                    <ul>
                        <li><a href="/">Strona główna</a></li>
                        <li><a href="/Gallery">Galeria</a></li>
                        <li><a href="/Events">Wydarzenia</a></li>
                        <li><a href="/Home/About">O nas</a></li>
                        <li><a href="/Home/Contact">Kontakt</a></li>
                        <li><a href="/FaqEntries">FAQ</a></li>
                    </ul>
                </div>
                <div class="footer-links">
                    <h4>Dla chórzystów</h4>
                    <ul>
                        <li><a asp-controller="ChoirDashboard" asp-action="Index">Panel chórzysty</a></li>
                        <li><a href="/Events">Kalendarz prób</a></li>
                        <li><a href="/Account/Login">Logowanie</a></li>
                        <li><a href="/Account/Register">Rejestracja</a></li>
                    </ul>
                </div>
                <div class="footer-contact">
                    <h4>Kontakt</h4>
                    <address>
                        <p><i class="bi bi-geo-alt"></i> ul. Muzyczna 1, 00-001 Warszawa</p>
                        <p><i class="bi bi-envelope"></i> <a href="mailto:choir@example.com">choir@example.com</a></p>
                        <p><i class="bi bi-telephone"></i> +48 221 123 456</p>
                    </address>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; @DateTime.Now.Year Chór Akademicki. Wszelkie prawa zastrzeżone.</p>
                <p>ASP.NET Core MVC</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>