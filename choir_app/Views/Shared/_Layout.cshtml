<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Choir App</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- FONTY -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">

    <!-- BOOTSTRAP ICONS -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/choir_app.styles.css" asp-append-version="true" />
</head>

<body>

    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg custom-navbar fixed-top">

            <div class="container">

                <!-- LOGO -->
                <a class="navbar-brand brand-logo"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">

                    <span class="text-gold">CHOIR</span> APP
                </a>

                <!-- MOBILE BUTTON -->
                <button class="navbar-toggler border-0 shadow-none"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">

                    <i class="bi bi-list text-light fs-1"></i>

                </button>

                <!-- MENU -->
                <div class="collapse navbar-collapse" id="navbarContent">

                    <ul class="navbar-nav ms-auto align-items-lg-center">

                        <li class="nav-item">
                            <a class="nav-link custom-link"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link custom-link"
                               href="#">
                                Koncerty
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link custom-link"
                               href="#">
                                Repertuar
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link custom-link"
                               href="#">
                                Galeria
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link custom-link"
                               href="#">
                                Kontakt
                            </a>
                        </li>

                      

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- CONTENT -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer-custom">

        <div class="container">

            <div class="row gy-4">

                <div class="col-lg-6">
                    <h3 class="footer-logo">
                        <span class="text-gold">CHOIR</span> APP
                    </h3>

                    <p class="footer-text">
                        Nowoczesna platforma do zarządzania chórem,
                        koncertami i repertuarem muzycznym.
                    </p>
                </div>

                <div class="col-lg-3">
                    <h5 class="footer-title">
                        Nawigacja
                    </h5>

                    <ul class="footer-links">
                        <li><a href="#">Home</a></li>
                        <li><a href="#">Koncerty</a></li>
                        <li><a href="#">Galeria</a></li>
                    </ul>
                </div>

                <div class="col-lg-3">
                    <h5 class="footer-title">
                        Kontakt
                    </h5>

                    <p class="footer-text">
                        choir@email.com
                    </p>
                </div>

            </div>

            <hr class="footer-divider" />

            <div class="text-center footer-copy">
                © 2026 Choir App
            </div>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>