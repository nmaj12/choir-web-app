@model IEnumerable<choir_app.Models.GalleryImage>

<h2>Galeria</h2>

@if (User.IsInRole("Admin") || User.IsInRole("Dyrygent"))
{
    <a asp-action="Upload" class="btn btn-primary">Dodaj zdjęcie</a>
}

<div class="row mt-3">
    @foreach (var img in Model)
    {
        <div class="col-md-3 mb-3">
            <div class="card">
                <img src="@img.ImageUrl"
                     class="card-img-top"
                     style="height:200px; object-fit:cover;" />

                <div class="card-body">
                    <p>@img.Title</p>

                    @if (User.IsInRole("Admin") || User.IsInRole("Dyrygent"))
                    {
                        <a asp-action="Delete"
                           asp-route-id="@img.Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Usunąć zdjęcie?')">
                            Usuń
                        </a>
                    }
                </div>
            </div>
        </div>
    }
</div>