<h2>Panel administratora</h2>

<div class="row">

    <div class="col-md-3 mb-3">
        <div class="card bg-dark text-white">
            <div class="card-body">
                <h5>Użytkownicy</h5>
                <h2>@ViewBag.UsersCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h5>Wydarzenia</h5>
                <h2>@ViewBag.EventsCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h5>Galeria</h5>
                <h2>@ViewBag.ImagesCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card bg-warning text-dark">
            <div class="card-body">
                <h5>Pliki</h5>
                <h2>@ViewBag.FilesCount</h2>
            </div>
        </div>
    </div>

</div>

<hr />

<div class="list-group">

    <a asp-controller="Events"
       asp-action="Index"
       class="list-group-item list-group-item-action">
        Zarządzanie wydarzeniami
    </a>

    <a asp-controller="Gallery"
       asp-action="Index"
       class="list-group-item list-group-item-action">
        Zarządzanie galerią
    </a>

    <a asp-controller="Files"
       asp-action="Index"
       class="list-group-item list-group-item-action">
        Zarządzanie plikami
    </a>

    <a asp-controller="News"
       asp-action="Index"
       class="list-group-item list-group-item-action">
        Zarządzanie ogłoszeniami
    </a>

    <a asp-controller="ChoirMembers"
       asp-action="Index"
       class="list-group-item list-group-item-action">
        Zarządzanie chórzystami
    </a>

    <a asp-controller="Attendance"
       asp-action="Index"
       class="list-group-item list-group-item-action">
        Zarządzanie obecnościami
    </a>

    @if (User.IsInRole("Admin"))
    {
        <a asp-controller="Admin"
           asp-action="Users"
           class="list-group-item list-group-item-action list-group-item-danger">
            Zarządzanie użytkownikami i rolami
        </a>
    }

</div>