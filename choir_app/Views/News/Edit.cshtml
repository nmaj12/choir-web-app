@model choir_app.Models.News

<h1>Edytuj news</h1>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div>
        <label>Tytuł</label>
        <input asp-for="Title" />
    </div>

    <div>
        <label>Treść</label>
        <textarea asp-for="Content"></textarea>
    </div>

    <button type="submit">Zapisz zmiany</button>

</form>